{
  "name": "nauticfinder-api",
  "version": "0.1.0",
  "description": "NauticFinder.ai — AI-powered nautical search and discovery platform backend",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "supabase:init": "pnpm exec supabase init",
    "supabase:login": "pnpm exec supabase login",
    "supabase:link": "pnpm exec supabase link --project-ref aadlgwyczuvnxdwjdbcx",
    "db:migrate:new": "pnpm exec supabase migration new",
    "db:reset": "pnpm exec supabase db reset --linked",
    "db:seed": "node --env-file=.env",
    "db:seed:all": "./database/util/seed-runner.sh",
    "db:types": "pnpm exec supabase gen types typescript --project-id aadlgwyczuvnxdwjdbcx > ./src/types/shared/database.types.ts",
    "prepare": "husky"
  },
  "keywords": [
    "nautical",
    "boats",
    "yachts",
    "ai",
    "search",
    "fastify"
  ],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.101.0",
    "bullmq": "^5.71.1",
    "cheerio": "^1.2.0",
    "date-fns": "^4.1.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.4",
    "ioredis": "^5.10.1",
    "nanoid": "^5.1.7",
    "openai": "^6.33.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "resend": "^6.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "supabase": "^2.84.5",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "supabase",
      "msgpackr-extract"
    ]
  }
}
