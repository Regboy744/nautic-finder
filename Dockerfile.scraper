# Playwright browser server container for scraping.
# Exposes a Playwright WebSocket endpoint on port 3001.
#
# Usage:
#   docker compose up scraper -d --build
#   # Host connects via: ws://localhost:3001/<guid>

FROM mcr.microsoft.com/playwright:v1.58.0-noble

WORKDIR /app

RUN npm init -y && npm install playwright@1.58.2

COPY docker/browser-server.mjs ./browser-server.mjs

EXPOSE 3001

CMD ["node", "browser-server.mjs"]
