# =============================================================================
# NauticFinder API — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# -- App --
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3001

# -- Database (Supabase PostgreSQL) --
DATABASE_URL=postgresql://postgres:password@localhost:5432/nauticfinder
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -- Redis --
REDIS_URL=redis://localhost:6379

# -- AI Services --
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=                    # Optional — for Claude reasoning
OPENAI_API_KEY=                       # For embeddings (text-embedding-3-small)

# -- Scraping --
PROXY_URL=                            # Optional — rotating proxy service URL
SCRAPER_USER_AGENT=NauticFinder/1.0

# -- Notifications --
RESEND_API_KEY=                       # For email delivery
WEB_PUSH_VAPID_PUBLIC_KEY=            # For push notifications
WEB_PUSH_VAPID_PRIVATE_KEY=

# -- Decodo Proxy --
DECODO_PROXY_ENABLED=false
DECODO_PROXY_MODE=userpass                # ip_whitelist | userpass
DECODO_PROXY_HOST=gate.decodo.com
DECODO_PROXY_PORT=7000
DECODO_PROXY_USERNAME=                    # Required for userpass mode
DECODO_PROXY_PASSWORD=                    # Required for userpass mode
DECODO_PROXY_PROTOCOL=http                # http | https
DECODO_PROXY_COUNTRY=                     # Force exit country (ISO 3166-1), empty = any
DECODO_PROXY_SESSION_STRATEGY=rotate      # rotate | sticky
DECODO_PROXY_SESSION_DURATION_MIN=30      # Sticky session duration in minutes
DECODO_PROXY_SESSION_ID_STRATEGY=per_job  # per_job | per_broker
DECODO_PROXY_TIMEOUT_MS=30000             # Proxy request timeout

# -- Auth --
JWT_SECRET=your-jwt-secret-min-32-chars
